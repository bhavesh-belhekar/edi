<group name="synthetic_telemetry,">
  <rule id="110000" level="3">
    <if_sid>86600</if_sid>
    <field name="event_id">\.+</field>
    <description>Synthetic telemetry event received: $(event_type)</description>
  </rule>

  <rule id="110001" level="7">
    <if_sid>110000</if_sid>
    <field name="severity">warning</field>
    <description>Synthetic warning event: $(event_type)</description>
  </rule>

  <rule id="110002" level="10">
    <if_sid>110000</if_sid>
    <field name="severity">high</field>
    <description>Synthetic high severity event: $(event_type)</description>
  </rule>

  <rule id="110003" level="12">
    <if_sid>110000</if_sid>
    <field name="severity">critical</field>
    <description>Synthetic critical event: $(event_type)</description>
  </rule>

  <rule id="110004" level="8">
    <if_sid>110000</if_sid>
    <field name="event_type">failed_login</field>
    <description>Synthetic failed login for user $(user.username)</description>
  </rule>

  <rule id="110005" level="12">
    <if_sid>110000</if_sid>
    <field name="event_type">firewall_allow|firewall_deny</field>
    <description>Synthetic firewall security event: $(event_type)</description>
  </rule>

</group>
